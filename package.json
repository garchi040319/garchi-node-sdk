{
  "name": "@garchicms/garchi-node-sdk",
  "description": "Node SDK for light weight wrapper for Garchi CMS API",
  "version": "0.0.7",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    "./types": "./dist/types/index.d.ts",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "/dist",
    "README.md"
  ],
  "scripts": {
    "test": "jest",
    "start": "node dist/index.js",
    "build": "tsup",
    "check-exports": "attw --pack ."
  },
  "keywords": [
    "headless cms",
    "garchi cms"
  ],
  "author": "Aditya Kadam",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/axios": "^0.14.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.1.0",
    "axios-mock-adapter": "^2.1.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "dotenv": "^17.2.3"
  }
}
